<div class="quick-shortcut @(IsOpen ? "show" : "")">
    <div class="quick-shortcut-header">
        <h4>Quick Shortcut</h4>
        <small>User Applications & Addons</small>
        <i class=""></i>
    </div>

    <div class="quick-shortcut-body">
        <ul class="quick-shortcut-list">
            <li>
                <a href="https://myaccount.microsoft.com/"
                   target="_blank"
                   class="quick-shortcut-item">
                    <div class="quick-shortcut-icon">
                        <i class="fa fa-user text-primary"></i>
                    </div>
                    <div class="quick-shortcut-label">Account</div>
                </a>
            </li>

            <li>
                <a href="https://outlook.office.com/mail/"
                   target="_blank"
                   class="quick-shortcut-item">
                    <div class="quick-shortcut-icon">
                        <img src="https://react.proserv360.tech/assets/outlook-icon-ComIkiQ6.jpeg" />
                    </div>
                    <div class="quick-shortcut-label">Outlook</div>
                </a>
            </li>

            <li>
                <a href="https://outlook.office.com/calendar/view/workweek/"
                   target="_blank"
                   class="quick-shortcut-item">
                    <div class="quick-shortcut-icon">
                        <i class="fa fa-calendar text-primary"></i>
                    </div>
                    <div class="quick-shortcut-label">Calendar</div>
                </a>
            </li>
        </ul>
    </div>
</div>

@code {
    private bool IsOpen;

    private void ToggleDropdown()
    {
        IsOpen = !IsOpen;
    }
}
<style>
    /* Card container */
    .quick-shortcut {
        width: 320px;
        background: #ffffff;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        overflow: hidden;
        font-family: "Segoe UI", sans-serif;
        z-index: 99999;
        /* margin-top: 284px; */
        position: absolute;
        right: 3px;
        top: 42px;
        display:none;
    }

        .quick-shortcut.show{
            display:block;
        }

    /* Header */
    .quick-shortcut-header {
        background: #4f80c0;
        padding: 18px 12px;
        text-align: center;
        color: #fff;
    }

        .quick-shortcut-header h4 {
            margin: 0;
            font-size: 18px;
            font-weight: 600;
        }

        .quick-shortcut-header small {
            display: block;
            margin-top: 4px;
            font-size: 13px;
            opacity: 0.9;
        }

    /* App grid */
    .quick-shortcut-body {
        padding: 20px 15px;
    }

    .quick-shortcut-list {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    /* App item */
    .quick-shortcut-item {
        text-align: center;
        text-decoration: none;
        color: #555;
        transition: transform 0.15s ease, color 0.15s ease;
    }

        .quick-shortcut-item:hover {
            transform: translateY(-3px);
            color: #4f80c0;
        }

    /* Icon */
    .quick-shortcut-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .quick-shortcut-icon i,
        .quick-shortcut-icon img {
            font-size: 42px;
            max-width: 100%;
            max-height: 100%;
        }

    /* Label */
    .quick-shortcut-label {
        font-size: 14px;
        font-weight: 500;
    }

</style>