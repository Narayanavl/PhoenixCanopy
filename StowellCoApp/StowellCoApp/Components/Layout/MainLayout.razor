<style>
    /* Card container */
    .quick-shortcut {
        width: 320px;
        background: #ffffff;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
        overflow: hidden;
        font-family: "Segoe UI", sans-serif;
        z-index: 99999;
        /* margin-top: 284px; */
        position: absolute;
        right: 25px;
        top: 45px;
        display: none;
    }

        .quick-shortcut.show {
            display: block;
        }

    /* Header */
    .quick-shortcut-header {
        background: #000;
        padding: 18px 12px;
        text-align: center;
        color: #fff;
    }

        .quick-shortcut-header h4 {
            margin: 0;
            font-size: 18px;
            font-weight: 600;
            color:#fff;
        }

        .quick-shortcut-header small {
            display: block;
            margin-top: 4px;
            font-size: 13px;
            opacity: 0.9;
        }

    /* App grid */
    .quick-shortcut-body {
        padding: 20px 15px;
    }

    .quick-shortcut-list {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 18px;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    /* App item */
    .quick-shortcut-item {
        text-align: center;
        text-decoration: none;
        color: #555;
        transition: transform 0.15s ease, color 0.15s ease;
    }

        .quick-shortcut-item:hover {
            transform: translateY(-3px);
            color: #4f80c0;
        }

    /* Icon */
    .quick-shortcut-icon {
        width: 56px;
        height: 56px;
        margin: 0 auto 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .quick-shortcut-icon i,
        .quick-shortcut-icon img {
            font-size: 40px;
            max-width: 100%;
            max-height: 100%;
        }

    /* Label */
    .quick-shortcut-label {
        font-size: 14px;
        font-weight: 500;
    }

    .rz-grid-table thead th{
        background-color:#000;
    }

        .rz-grid-table thead th .rz-column-title{
            color:#fff;
        }

   /*  .quick-shortcut a{
        cursor:none;
    } */
    .right-bar .text-xs{
        text-align:center;
    }
</style>