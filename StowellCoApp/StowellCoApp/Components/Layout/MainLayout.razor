@code {
    private bool RightMenuOpen { get; set; } = true;

    private void ToggleRightMenu()
    {
        RightMenuOpen = !RightMenuOpen;
    }

    private bool IsOpen;

    private void CloseDropdown()
    {
        IsOpen = false;
    }
    private void ToggleDropdown()
    {
        IsOpen = !IsOpen;
    }
    private void HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape")
        {
            IsOpen = false;
        }
    }
    private async Task GoToPasswordPage()
    {
        await JS.InvokeVoidAsync(
            "openInNewTab",
            "https://stowell.proserv360.tech/RDWeb/Pages/en-US/password.aspx");
    }
    private void Logout()
    {
        Navigation.NavigateTo("authentication/logout", forceLoad: true);
    }
}
