                <i class="fa-solid fa-user-gear" style="color:#fff;"></i> Phoenix Admin
            </NavLink></li>
        <li>
            <NavLink>
                <i class="fas fa-phone" style="color:#fff;"></i> Contacts
                @* <i class="fas fa-address-book"></i> Contacts *@
