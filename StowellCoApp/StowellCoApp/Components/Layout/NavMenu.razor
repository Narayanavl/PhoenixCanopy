</nav>
<div class="icon-toolbar">
  @*   <button title="Support" onclick="window.location.href='mailto:support@proserv360.tech'">
        <i class="fas fa-handshake"></i>
    </button> *@
    <button class="icon-btn" title="Support" aria-label="Support" onclick="window.location.href='mailto:support@proserv360.tech'">
        <i class="fas fa-handshake"></i></button>
    <button class="icon-btn" title="Password Management" 
    @onclick="GoToPasswordPage" aria-label="Password Management"><i class="fas fa-key"></i></button>

 @*    <button title="Key">
        <i class="fas fa-key"></i>
    </button> *@
    <button title="Download" @onclick="ToggleDropdown" aria-label="More Apps"
            @onclick:stopPropagation="true">
        
        <i class="fas fa-arrow-alt-circle-down"></i>
    </button>
    <div class="quick-shortcut @(IsOpen ? "show" : "")">
        <div class="quick-shortcut-header">
            <h4>Quick Shortcut</h4>
            <small>User Applications & Addons</small>
            <i class=""></i>
        </div>

        <div class="quick-shortcut-body">
            <ul class="quick-shortcut-list">
                <li>
                    <a href="https://myaccount.microsoft.com/"
                       target="_blank"
                       class="quick-shortcut-item">
                        <div class="quick-shortcut-icon">
                            <i class="fa fa-user text-primary"></i>
                        </div>
                        <div class="quick-shortcut-label">Account</div>
                    </a>
                </li>

                <li>
                    <a href="https://outlook.office.com/mail/"
                       target="_blank"
                       class="quick-shortcut-item">
                        <div class="quick-shortcut-icon">
                            <img src="https://react.proserv360.tech/assets/outlook-icon-ComIkiQ6.jpeg" />
                        </div>
                        <div class="quick-shortcut-label">Outlook</div>
                    </a>
                </li>

                <li>
                    <a href="https://outlook.office.com/calendar/view/workweek/"
                       target="_blank"
                       class="quick-shortcut-item">
                        <div class="quick-shortcut-icon">
                            <i class="fa fa-calendar text-primary"></i>
                        </div>
                        <div class="quick-shortcut-label">Calendar</div>
                    </a>
                </li>
            </ul>
        </div>
    </div>
    <button title="Logout" @onclick="Logout">
        <i class="fas fa-sign-out-alt"></i>
    </button>
</div>

@code {
    // State for top-level menu
    private string? OpenMenu = null;

    // State for second-level (nested) submenu
    private string? OpenSubMenu = null;

    // Toggle top-level menu
    private void ToggleMenu(string menuName, string? url = null)
    {
        if (OpenMenu == menuName)
        {
            OpenMenu = null; // Close menu if already open
        }
        else
        {
            OpenMenu = menuName; // Open menu
        }

        // Navigate if URL is provided
        if (!string.IsNullOrEmpty(url))
        {
            NavigationManager.NavigateTo(url);
        }
    }

    // Toggle nested submenu
    // private void ToggleSubMenu(string submenuName)
    // {
    //     OpenSubMenu = OpenSubMenu == submenuName ? null : submenuName;
    // }
    private void ToggleSubMenu(string submenuName, string? url = null)
    {
        OpenSubMenu = OpenSubMenu == submenuName ? null : submenuName;
        // Navigate if URL is provided
        if (!string.IsNullOrEmpty(url))
        {
            NavigationManager.NavigateTo(url);
        }
    }
    private async Task GoToPasswordPage()
    {
        await JS.InvokeVoidAsync(
            "openInNewTab",
            "https://stowell.proserv360.tech/RDWeb/Pages/en-US/password.aspx");
    }
    private bool IsOpen;

    
    private void ToggleDropdown()
    {
        IsOpen = !IsOpen;
    }
    private void Logout()
    {
        NavigationManager.NavigateTo("authentication/logout", forceLoad: true);
    }
}
<style>
    .menu-arrow {
        font-size: 13px; /* smaller arrow */
        line-height: 1; /* keeps it aligned vertically */
        vertical-align: middle; /* aligns with text and icons */
        transition: transform 0.2s ease; /* optional: for rotation animation */
        display: inline-block; /* needed if you want to rotate the arrow */
    }

        /* Optional: rotate arrow when menu is open */
        .menu-arrow.open {
            transform: rotate(180deg);
        }

</style>