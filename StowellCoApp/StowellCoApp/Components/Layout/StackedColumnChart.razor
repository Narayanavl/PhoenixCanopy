@code {
    bool smooth = false;
    bool sharedTooltip = true;
    bool showDataLabels = false;
    bool showMarkers = true;
    private IEnumerable<ChartData> chartDatasets;

    [Inject]
    public IJobService JobService { get; set; }
    [Inject]
    private ILogger<StackedColumnChart> logger { get; set; } = default!;
    class DataItem
    {
        public string Quarter { get; set; }
        public double Revenue { get; set; }
    }

    string FormatAsUSD(object value)
    {
        return ((double)value).ToString("C0", CultureInfo.CreateSpecificCulture("en-US"));
    }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) // important to avoid infinite loops
        {
            try
            {
                //logger.LogInformation("OnAfterRenderAsync start");
                chartDatasets = await JobService.GetSampleChartDatasets();
                var chart = chartDatasets.FirstOrDefault(); // since you only have one dataset
                var dataset = chart.Datasets[0]; // first dataset

                retainChartData = chart.Labels
     .Select((label, index) => new DataItem
         {
             Quarter = label,
             Revenue = Convert.ToDouble(dataset.Data[index])
         })
     .GroupBy(x => x.Quarter)           // group by label
     .Select(g => g.First())            // keep first occurrence
     .ToList();
                // Assuming retainChartData is your original list of DataItem
                var max = retainChartData.Max(d => d.Revenue);
                var min = retainChartData.Min(d => d.Revenue);

                // Create datasets for Radzen
                 highestDataset = retainChartData
                    .Select(d => new DataItem
                    {
                        Quarter = d.Quarter,
                        Revenue = d.Revenue == max ? d.Revenue : 0
                    })
                    .ToList();

                 lowestDataset = retainChartData
                    .Select(d => new DataItem
                    {
                        Quarter = d.Quarter,
                        Revenue = d.Revenue == min ? d.Revenue : 0
                    })
                    .ToList();

                 regularDataset = retainChartData
                    .Select(d => new DataItem
                    {
                        Quarter = d.Quarter,
                        Revenue = (d.Revenue != max && d.Revenue != min) ? d.Revenue : 0
                    })
                    .ToList();

                StateHasChanged(); // optional, usually not needed in firstRender
            }
            catch (Exception ex)
            {
                logger.LogInformation($"Error loading chartdataset: {ex.Message}");
                Console.WriteLine($"Error loading chartdataset: {ex.Message}");
            }
        }
    }
    private List<DataItem> retainChartData = new();
    private List<DataItem> regularDataset = new();
    private List<DataItem> lowestDataset = new();
    private List<DataItem> highestDataset = new();

    protected override void OnInitialized()
    {
        
    }

}
<style>
    .responsive-chart-container {
        width: 100%;
        overflow: hidden; /* No horizontal scroll */
    }

    .responsive-chart {
        width: 100% !important;
        height: 400px; /* Or auto if you want */
    }

</style>