@using Microsoft.AspNetCore.Components

<header class="topbar flex items-center justify-between bg-white shadow px-6 py-3">

    <!-- Left placeholder (optional, could be logo) -->
    <div class="flex-1"></div>

    <!-- Center: Search Box -->
    <div class="flex-1 flex justify-center">
        <div class="relative w-1/2">
            <input type="text" placeholder="Search for anything..."
                   class="w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring focus:ring-blue-400" />
            <i class="bi bi-search absolute left-3 top-2.5 text-gray-500"></i>
        </div>
    </div>

    <!-- Right: Icons + Toggle -->
    <div class="flex items-center space-x-3 top-icons">

        <!-- Download / Other Action -->
        <button class="icon-btn" title="More Apps">
            <i class="bi bi-download"></i>
        </button>

        <!-- Search Icon -->
        <button class="icon-btn" title="Password Management">
            <i class="fas fa-key"></i>
        </button>
        <button class="icon-btn" title="Password Management">
            <i class="bi bi-shield-lock"></i>
        </button>

        <!-- Help -->
        <button class="icon-btn" title="Help">
            <i class="bi bi-question-circle"></i>
        </button>

        <!-- Profile -->
        <button class="icon-btn" title="Profile">
            <i class="bi bi-person-circle"></i>
        </button>

        <!-- Toggle Right Slim Menu -->
        <button class="icon-btn" title="Toggle Right Menu"
                @onclick="() => OnToggleRightMenu.InvokeAsync()">
            <i class="fas fa-bars"></i>
        </button>
    </div>

</header>

@code {
    [Parameter] public EventCallback OnToggleRightMenu { get; set; }
}
