@page "/Bids/NewBid"
@inherits NewBidBase
@using System.Globalization
@using Radzen
@using Radzen.Blazor
@inject NavigationManager Nav
<PageTitle>New Opportunity</PageTitle>
<h3>New Opportunity</h3>
<hr />

<div class="wrapper wrapper-content" style="background: #f7f7f7">

    <div class="row white-bg p-10 my-3" style="margin-left:5px;">
        <div class="col-lg-12">

            <div class="mb-3">
                <div class="row col-md-8 mr-3">

                    @if (createBidRequest == null)
                    {
                        <p>loading..</p>
                    }
                    else
                    {
                        <EditForm Model="@createBidRequest"
                                  OnValidSubmit="SaveBid"
                                  autocomplete="off">

                            <!-- Bid Id -->
                            <div class="form-row">
                                <label>Opportunity ID</label>
                                <input class="form-control small-input"
                                       value="@createBidRequest.BidId"
                                       readonly />
                            </div>

                            <!-- Department / Division -->
                            <div class="form-row two-column">

                                <div class="field-group">
                                    <label>Department</label>
                                    <select class="form-control medium-input"
                                            @bind="createBidRequest.Department">
                                        <option value="">Select Department</option>
                                        <option value="Drywall">Drywall</option>
                                        <option value="Block/Concrete">Block/Concrete</option>
                                    </select>
                                </div>

                                <div class="field-group">
                                    <label>Division</label>
                                    <select class="form-control medium-input"
                                            @bind="createBidRequest.Division">
                                        <option value="">Select Division</option>
                                        <option>Orlando</option>
                                        <option>Naples</option>
                                        <option>Jacksonville</option>
                                        <option>Tampa</option>
                                        <option>Texas</option>
                                    </select>
                                </div>

                            </div>

                            <!-- Bid Name -->
                            <div class="form-row">
                                <label>Opportunity Name</label>
                                <input class="form-control large-input"
                                       @bind="createBidRequest.BidName"
                                       autocomplete="off" />
                            </div>

                            <!-- Address -->
                            <div class="form-row">
                                <label>Address</label>
                                <input class="form-control address-input"
                                       @bind="createBidRequest.Address1"
                                       autocomplete="off" />
                            </div>

                            <!-- City / State / Zip -->
                            <div class="form-row city-row">

                                <div class="field-group">
                                    <label>City</label>
                                    <input class="form-control city-input"
                                           @bind="createBidRequest.City"
                                           autocomplete="off" />
                                </div>

                                <div class="field-group state-group">
                                    <label>State</label>
                                    <select class="form-control state-input"
                                            @bind="createBidRequest.State">
                                        <option value="">Select State</option>
                                        <option>NC</option>
                                        <option>SC</option>
                                        <option>FL</option>
                                    </select>
                                </div>

                                <div class="field-group zip-group">
                                    <label>Zip</label>
                                    <input class="form-control zip-input"
                                           @bind="createBidRequest.ZipCode"
                                           autocomplete="off" />
                                </div>

                            </div>

                            <!-- Buttons -->
                            <div class="button-row">

                                <button type="button"
                                        class="btn btn-secondary"
                                        @onclick="Cancel">
                                    Cancel
                                </button>

                                <button type="submit"
                                        class="btn btn-primary"
                                        disabled="@IsSaving" style="background-color:#000 !important;border-color:#000 !important">
                                    @(IsSaving ? "Saving..." : "Create")
                                </button>

                            </div>

                        </EditForm>
                    }

                </div>
            </div>
        </div>
    </div>
</div>
<div class="bid-container">

    @*  <!-- Header -->
    <div class="header-section">
        <img src="images/stowell-logo.png" class="logo" />
        <div class="title-wrapper">
            <h3>New Bid</h3>
            <hr />
        </div>
    </div> *@

    <!-- FORM -->

</div>

<style>

    /*  body {
            font-family: Arial, Helvetica, sans-serif;
        }
     */
    /*  .bid-container {
            width: 760px;
            border: 1px solid #999;
            padding: 12px 18px 20px 18px;
            background: #f7f7f7;
        } */

    /* HEADER */

    .header-section {
        display: flex;
        align-items: flex-start;
        margin-bottom: 18px;
    }

    @* .logo {
        width: 58px;
        margin-right: 14px;
    } *@

    .title-wrapper {
        flex: 1;
    }

        .title-wrapper h3 {
            margin: 0;
            font-size: 34px;
            font-weight: 400;
            color: #111;
        }

        .title-wrapper hr {
            margin-top: 6px;
            border-top: 2px solid #666;
        }

    /* FORM ROWS */

    .form-row {
        display: flex;
        align-items: center;
        margin-bottom: 14px;
    }

        .form-row label {
            width: 150px;
            font-size: 15px;
            color: #333;
            margin-right: 10px;
        }

    .two-column {
        gap: 10px;
    }

    .field-group {
        display: flex;
        align-items: center;
    }

        .field-group label {
            width: 150px;
            margin-right: 10px;
        }

    /* INPUTS */

    .form-control {
        height: 32px;
        border: 1px solid #8a8a8a;
        border-radius: 4px;
        padding: 4px 10px;
        background: white;
        box-shadow: none;
    }

    .small-input {
        width: 210px;
    }

    .medium-input {
        width: 210px;
    }

    .large-input {
        width: 589px;
    }

    .address-input {
        width: 590px;
    }

    .city-input {
        width: 240px;
    }

    .state-input {
        width: 120px;
    }

    .zip-input {
        width: 240px;
    }

    .city-row {
        gap: 18px;
    }

    /* BUTTONS */

    .button-row {
        display: flex;
        justify-content: flex-end;
        margin-top: 24px;
        gap: 12px;
    }

    .btn {
        min-width: 82px;
        height: 34px;
        border-radius: 4px;
        border: 1px solid #999;
        font-size: 14px;
    }

    .btn-cancel {
        background-color: #f2d6dc;
    }

    .btn-create {
        background-color: #f5f5f5;
    }

</style>