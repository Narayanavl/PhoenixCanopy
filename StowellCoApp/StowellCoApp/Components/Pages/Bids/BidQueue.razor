@page "/Bids/BidQueue"
<PageTitle>Opportunity Queue</PageTitle>
<h3>Opportunity Queue</h3>
<hr />
@using Radzen
@using Radzen.Blazor
@using StowellCoApp.DTO
@using StowellCoApp.Services
@inject NavigationManager navigationManager

<div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="m-0">Current Opportunities</h3>

    <div class="doclibrary">
        <a href="/BidsDocManagement/Main" target="_blank" style="color:#FE866D !important;">
            <i class="fa fa-folder me-1"></i>
            Opportunities Document Library
        </a>
    </div>
</div>
<hr />
<div class="dashboard-container">
    <div class="gridcard">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <!-- Left: Search box with icon -->

            <div style="display: flex; align-items: center; /* gap: 8px; */">
                <RadzenIcon Icon="search"
                            style="
                    cursor: pointer;
                    background-color: #000;
                    padding: 8px;
                    border-radius: 4px;
                    color: #fff;
                    font-size: 18px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    height: 36px;
                    width: 36px;
border-bottom-right-radius:0;
border-top-right-radius:0
                " />
                <RadzenTextBox @bind-Value="searchCurrentTerm"
                               Placeholder="Search Opportunities..."
                               Style="width: 300px; height: 36px; font-size: 14px;" @oninput="OnInputCurrentChanged" />
                <button style="background-color:#000;border-color:#000" class="btn btn-primary col-lg-4 mx-2" type="button" @onclick="() => navigationManager.NavigateTo(newBidUrl)">New Opportunity</button>

            </div>
            <div style="display:flex; align-items:center; gap:5px;">
                <span>Show</span>
                <RadzenDropDown @bind-Value="selectedCurrentPageSize" Data="pageSizes" Style="width:80px;" Change="OnCurrentPageSizeChangedInput" />
                <span>entries</span>
            </div>

        </div>




        <RadzenDataGrid @ref="currentgrid"
                        Data="@filteredCurrentBids"
                        TItem="Bids"
                        AllowPaging="true" PageSize="@pageSize" AllowSorting="true" AllowFiltering="true"
                        ShowPagingSummary="true" Count="@(filteredCurrentBids != null ? filteredCurrentBids.Count() : 0)">
            <Columns>
                <!-- Hyperlink column -->
                <RadzenDataGridColumn TItem="Bids" Title="Opportunity ID">
                    <Template Context="bid">
                        <a href="@($"/Bids/BidOverview/{bid.BidId}/current")">
                            @bid.BidId
                        </a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Bids" Property="BidName" Title="Opportunity Name" />
                <RadzenDataGridColumn TItem="Bids" Property="BidManager" Title="Opportunity Manager" />
                <RadzenDataGridColumn TItem="Bids" Property="Status" Title="Status" />

            </Columns>
        </RadzenDataGrid>

    </div>
</div>
<div class="card-header d-flex justify-content-between align-items-center">
    <h3 class="m-0">Closed Opportunities</h3>
</div>
<hr />
<div class="dashboard-container">
    <div class="gridcard">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
            <!-- Left: Search box with icon -->

            <div style="display: flex; align-items: center; /* gap: 8px; */">
                <RadzenIcon Icon="search"
                            style="
                    cursor: pointer;
                    background-color: #000;
                    padding: 8px;
                    border-radius: 4px;
                    color: #fff;
                    font-size: 18px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    height: 36px;
                    width: 36px;
border-bottom-right-radius:0;
border-top-right-radius:0
                " />
                <RadzenTextBox @bind-Value="searchClosedTerm"
                               Placeholder="Search Opportunities..."
                               Style="width: 300px; height: 36px; font-size: 14px;" @oninput="OnInputClosedChanged" />
            </div>
            <div style="display:flex; align-items:center; gap:5px;">
                <span>Show</span>
                <RadzenDropDown @bind-Value="selectedClosedPageSize" Data="pageSizes" Style="width:80px;" Change="OnClosedPageSizeChangedInput" />
                <span>entries</span>
            </div>

        </div>




        <RadzenDataGrid @ref="closedgrid"
                        Data="@filteredClosedBids"
                        TItem="Bids"
                        AllowPaging="true" PageSize="@pageSize" AllowSorting="true" AllowFiltering="true"
                        ShowPagingSummary="true" Count="@(filteredClosedBids != null ? filteredClosedBids.Count() : 0)">
            <Columns>
                <!-- Hyperlink column -->
                <RadzenDataGridColumn TItem="Bids" Title="Opportunity ID">
                    <Template Context="bid">
                        <a href="@($"/Bids/BidOverview/{bid.BidId}/Closed")">
                            @bid.BidId
                        </a>
                    </Template>
                </RadzenDataGridColumn>
                <RadzenDataGridColumn TItem="Bids" Property="BidName" Title="Opportunity Name" />
                <RadzenDataGridColumn TItem="Bids" Property="BidManager" Title="Opportunity Manager" />
                <RadzenDataGridColumn TItem="Bids" Property="Status" Title="Status" />

            </Columns>
        </RadzenDataGrid>

    </div>
</div>
@code {
    [Inject]
    public IBidService BidService { get; set; }
    [Inject]
    private ILogger<BidQueueDTO> logger { get; set; } = default!;
    private RadzenDataGrid<Bids> currentgrid;
    private RadzenDataGrid<Bids> closedgrid;
    private IEnumerable<Bids> filteredCurrentBids;
    private IEnumerable<Bids> filteredClosedBids;
    private string searchCurrentTerm = string.Empty;
    private string searchClosedTerm = string.Empty;
    private BidQueueDTO bidQueueData;
    private IEnumerable<Bids> pagedcurrentbids;
    private IEnumerable<Bids> pagedclosedbids;
    private CancellationTokenSource ctscurrent = new();
    private CancellationTokenSource ctsclosed = new();
    IEnumerable<int> pageSizeOptions = new int[] { 10, 20, 50 };
    bool showPagerSummary = true;
    private string newBidUrl = "/Bids/NewBid";
    // async Task FirstPage()
    // {
    //     await dataGrid.FirstPage();
    // }
    // async Task TenthPage()
    // {
    //     await dataGrid.GoToPage(9);
    // }
    // async Task LastPage()
    // {
    //     await dataGrid.LastPage();
    // }
    // void OnPage(PagerEventArgs args)
    // {
    //     //
    // }
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender) // important to avoid infinite loops
        {
            try
            {
                bidQueueData = await BidService.GetBidQueueData();
                logger.LogInformation("filteredBids start");
                filteredCurrentBids = bidQueueData != null && bidQueueData.CurrentBids!=null ? bidQueueData.CurrentBids:new List<Bids>();
                filteredClosedBids = bidQueueData != null && bidQueueData.ClosedBids != null ? bidQueueData.ClosedBids : new List<Bids>();
                StateHasChanged(); // optional, usually not needed in firstRender
            }
            catch (Exception ex)
            {
                logger.LogInformation($"Error loading bids: {ex.Message}");
                Console.WriteLine($"Error loading bids: {ex.Message}");
            }
        }
    }
    private async Task OnInputCurrentChanged(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        searchCurrentTerm = args.Value?.ToString() ?? string.Empty;

        // Cancel previous debounce
        ctscurrent.Cancel();
        ctscurrent = new CancellationTokenSource();
        var token = ctscurrent.Token;

        try
        {
            await Task.Delay(300, token); // debounce 300ms

            if (token.IsCancellationRequested) return;

            FilterCurrentBids();
        }
        catch (TaskCanceledException)
        {
            // ignore
        }
    }
    private async Task OnInputClosedChanged(Microsoft.AspNetCore.Components.ChangeEventArgs args)
    {
        searchClosedTerm = args.Value?.ToString() ?? string.Empty;

        // Cancel previous debounce
        ctsclosed.Cancel();
        ctsclosed = new CancellationTokenSource();
        var token = ctsclosed.Token;

        try
        {
            await Task.Delay(300, token); // debounce 300ms

            if (token.IsCancellationRequested) return;

            FilterClosedBids();
        }
        catch (TaskCanceledException)
        {
            // ignore
        }
    }
    private void FilterCurrentBids()
    {
        if (string.IsNullOrWhiteSpace(searchCurrentTerm))
        {
            filteredCurrentBids = bidQueueData != null && bidQueueData.CurrentBids != null ? bidQueueData.CurrentBids : new List<Bids>();
        }
        else
        {
            filteredCurrentBids = bidQueueData.CurrentBids.Where(j =>
                (Convert.ToString(j.BidId)?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.BidName?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.Bidder?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.BidManager?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.Status?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            );
           
        }

        currentgrid.Reload();
    }
    private void FilterClosedBids()
    {
        if (string.IsNullOrWhiteSpace(searchClosedTerm))
        {
            filteredClosedBids = bidQueueData != null && bidQueueData.ClosedBids != null ? bidQueueData.ClosedBids : new List<Bids>();
        }
        else
        {
            filteredClosedBids = bidQueueData.ClosedBids.Where(j =>
                (Convert.ToString(j.BidId)?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.BidName?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.Bidder?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.BidManager?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (j.Status?.Contains(searchCurrentTerm, StringComparison.OrdinalIgnoreCase) ?? false)
            );

        }

        closedgrid.Reload();
    }
    private string selectedCurrentPageSize = "10"; // default
    private string selectedClosedPageSize = "10"; // default
    private string[] pageSizes = new string[] { "10", "20", "50", "All" };
    private int pageSize = 10;
    private int currentPage = 0;
    // private void OnPageSizeChanged(int newPageSize)
    // {
    //     pageSize = newPageSize;
    //     currentPage = 0; // reset to first page
    //     ApplyPaging();
    // }
    private void OnCurrentPageSizeChangedInput(object value)
    {
        selectedCurrentPageSize = value.ToString();

        if (selectedCurrentPageSize == "All")
        {
            // Show all records
            pageSize = filteredCurrentBids?.Count() ?? 0;
        }
        else
        {
            pageSize = Convert.ToInt32(selectedCurrentPageSize);
        }

        currentPage = 0;

        // Refresh the grid and pager
        currentgrid.GoToPage(0);
        currentgrid.Reload();
    }
    private void OnClosedPageSizeChangedInput(object value)
    {
        selectedClosedPageSize = value.ToString();

        if (selectedClosedPageSize == "All")
        {
            // Show all records
            pageSize = filteredCurrentBids?.Count() ?? 0;
        }
        else
        {
            pageSize = Convert.ToInt32(selectedClosedPageSize);
        }

        currentPage = 0;

        // Refresh the grid and pager
        closedgrid.GoToPage(0);
        closedgrid.Reload();
    }
    // private void ApplyPaging()
    // {
    //     if (pageSize == 0)
    //     {
    //         pagedcurrentbids = filteredCurrentBids;
    //     }
    //     else
    //     {
    //         pagedbids = filteredCurrentBids
    //             .Skip(currentPage * pageSize)
    //             .Take(pageSize);
    //     }
    //     grid?.Reload();
    // }
    // private async Task OnLoadData(LoadDataArgs args)
    // {
    //     // Handle search
    //     filteredCurrentBids = string.IsNullOrWhiteSpace(searchCurrentTerm)
    //         ? bidQueueData != null && bidQueueData.CurrentBids != null ? bidQueueData.CurrentBids : new List<Bids>()
    //         : bidQueueData.CurrentBids.Where(j =>
    //             (Convert.ToString(j.BidId)?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
    //             (j.BidName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
    //             (j.Bidder?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
    //             (j.BidManager?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false) ||
    //             (j.Status?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ?? false));

    //     // Handle paging
    //     pagedbids = pageSize == 0
    //         ? filteredCurrentBids
    //         : filteredCurrentBids.Skip(args.Skip ?? 0).Take(args.Top ?? pageSize);

    //     StateHasChanged();
    // }


    // private void OnPageChanged(int newPageIndex)
    // {
    //     currentPage = newPageIndex;
    //     ApplyPaging();
    // }
}
<style>
    /* Put SUMMARY on its own line */
    .rz-pager-summary {
        display: block;
        width: 100%;
        margin-bottom: 6px;
    }

    /* Make the TWO pager sections share one row */
    .rz-pager .rz-pager-pages {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 8px;
    }

        /* Prevent Radzen from forcing internal wrapping */
        .rz-pager .rz-paginator,
        .rz-pager .rz-pager-pages > div {
            white-space: nowrap;
            flex-wrap: nowrap !important;
        }

    .rz-grid-table thead th {
        background-color: var(--rz-series-1);
    }

        .rz-grid-table thead th .rz-column-title, .rz-grid-filter-icon {
            color: #fff;
        }

</style>