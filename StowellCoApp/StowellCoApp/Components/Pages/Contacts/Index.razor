<RadzenTabs TabPosition="tabPosition"
            SelectedIndexChanged="OnTabIndexChanged"
            SelectedIndex="@selectedIndex">

    <Tabs>
        @foreach (var tab in contactGroups)
        {
            <RadzenTabsItem Text="@tab.DisplayName" @key="tab.Id">
                <h3>@tab.DisplayName</h3>

                @if (isLoading)
                {
                    <div class="text-center mt-3">
                        @* <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" Style="width:50%;" /> *@
                        <p>Loading members...</p>
                    </div>
                }
                else
                {
                    <div class="row">
                        @if (contactGroupMembers != null && contactGroupMembers.Any())
                        {
                            @foreach (var member in contactGroupMembers)
                            {
                                <div class="col-lg-4">
                                    <div class="contact-box">
                                        <div class="row">
                                            <div class="col-4 text-center">
                                                @if (!string.IsNullOrEmpty(member.photoBase64))
                                                {
                                                    <img src="data:image/jpeg;base64,@member.photoBase64"
                                                         alt="User Photo"
                                                         style="width:100px;height:100px;border-radius:100%" />
                                                }
                                                else
                                                {
                                                    <img src="/img/demo/avatars/icon-dummy-user.png"
                                                         class="rounded-circle mt-1 img-fluid" />
                                                }
                                                <div class="mt-1 font-bold">@member.JobTitle</div>
                                            </div>
                                            <div class="col-8 custom-address">
                                                <h3><strong>@member.DisplayName</strong></h3>
                                                @if (!string.IsNullOrEmpty(member.StreetAddress))
                                                {
                                                    <i class="fa-solid fa-location-dot" style="color:gray;margin-right:5px"></i>
                                                    <a href="@member.StreetAddress" target="_blank">@member.StreetAddress</a>
                                                }
                                                <address>
                                                    @if (!string.IsNullOrEmpty(member.City) ||
                                                         !string.IsNullOrEmpty(member.State) ||
                                                         !string.IsNullOrEmpty(member.PostalCode) ||
                                                         !string.IsNullOrEmpty(member.Phone))
                                                    {
                                                        <span>
                                                            @member.City, @member.State @member.PostalCode<br>
                                                            <span title="Phone">P:</span> @member.Phone<br>
                                                        </span>
                                                    }
                                                    <a href="mailto:@member.Mail">@member.Mail</a>
                                                </address>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <p>No members in this group.</p>
                            </div>
                        }
                    </div>
                }
            </RadzenTabsItem>
        }
    </Tabs>
</RadzenTabs>

