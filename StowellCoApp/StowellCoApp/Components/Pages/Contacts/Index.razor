<style>
    /* -----------------------------
               TAB NAVIGATION
            --------------------------------*/
            .rz-tabview-top>.rz-tabview-nav li{
               width: 170px;
    margin: 5px;
            }
    .nav-tabs .nav-link {
        padding: 10px 18px;
        font-weight: 600;
        color: #555;
        border-radius: 0;
        transition: background-color .25s, color .25s, border-color .25s;
    }

        .nav-tabs .nav-link:hover {
            background-color: #f5f5f5;
            color: #222;
        }

        .nav-tabs .nav-link.active {
            background-color: #fff;
            color: #007bff;
            border-color: #dee2e6 #dee2e6 #fff;
            border-bottom: 2px solid #007bff;
        }

    /* Better spacing between tabs */
    .nav-tabs .nav-item {
        margin-right: 5px;
    }

    /* Remove focus outline when clicking tabs */
    .nav-tabs .nav-link:focus {
        box-shadow: none;
    }

    /* -----------------------------
               TAB CONTENT BOX
            --------------------------------*/

    .tab-content-box,
    .project-tab-box {
        background-color: #fff;
        border: 1px solid #dee2e6;
        border-top: none;
        padding: 20px;
        border-radius: 0 0 4px 4px;
    }

    /* Slight fade animation on tab switch */
    .tab-switch-fade {
        animation: fadeIn .25s ease;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    /* -----------------------------
               DATA ROWS & LABEL STYLING
            --------------------------------*/

    .row.mb-2 {
        padding: 6px 0;
    }

    .row .font-weight-bold {
        color: #444;
    }

    /* Optional alternating background rows */
    .row.mb-2:nth-child(odd) {
        background-color: #fafafa;
    }

    /* -----------------------------
               TABLE STYLING (Financials / Reporting)
            --------------------------------*/

    .table th {
        background-color: #f1f1f1;
        font-weight: 600;
    }

    .table td,
    .table th {
        vertical-align: middle;
    }

    /* Improve table borders */
    .table-bordered td,
    .table-bordered th {
        border-color: #dcdcdc;
    }

    /* Hover effect for table rows */
    .table-striped tbody tr:hover {
        background-color: #f0f0f0;
        cursor: default;
    }

    .nav-tabs {
        display: flex;
        list-style: none;
    }

    h2 {
        text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff;
        color: #676a6c !important;
        font-weight: 500;
    }
    /* Ensure RadzenTabs container wraps its children */
.rz-tabview-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start; /* Optionally adjust alignment of wrapped items */
}

/* Adjust width of individual tabs so they fit nicely */
.rz-tabview-nav .rz-tabview-item {
    flex: 1 1 100px;  /* Minimum width of 100px per tab */
    max-width: 200px;  /* Optional: max-width per tab */
    margin: 2px;  /* Optional: space between tabs */
}

/* Optional: Style for better tab visual appearance */
.rz-tabview-nav .rz-tabview-item {
    white-space: nowrap;  /* Prevent text overflow */
}
.custom-address h3{
    color: gray;
    font-weight: normal;
}
.rz-tabview-nav .rz-tabview-selected {
    background-color: #000;
    color:#fff !important;
    border-top-color:#FE866D;
}
.rz-tabview-top>.rz-tabview-nav .rz-tabview-selected{
border-top-color:#FE866D;
}
.rz-tabview-top>.rz-tabview-nav li:hover:not(.rz-tabview-selected):not(.rz-state-disabled){
    border-top-color:#FE866D;
}
.rz-tabview-top>.rz-tabview-nav li{
    color:#000;
}

</style>


