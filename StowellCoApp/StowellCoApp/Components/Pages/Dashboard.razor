@code
{
    private IEnumerable<MyEventViewModel>? calendarEvents;
    private bool showCalendar = true;
    private string ToggleButtonText => showCalendar ? "List View" : "Calendar View";
    private Dictionary<DateTime, List<MyEventViewModel>> GroupedEvents { get; set; } = new();
    private RadzenScheduler<MyEventViewModel>? scheduler;
    private bool _schedulerInitialized;
    private string GetCurrentView()
    {
        if (scheduler == null)
            return "Month";

        var days = (scheduler.SelectedView.EndDate - scheduler.SelectedView.StartDate).TotalDays;

        if (days <= 1)
            return "Day";

        if (days <= 7)
            return "Week";

        return "Month";
    }

    // protected override async Task OnInitializedAsync()
    // {
    //     calendarEvents = await ApiClient.GetUserCalendarAsync("hr@stowellinc.com");
    //     // var view = GetCurrentView();
    //     // // GroupEvents();
    //     // var test = scheduler.SelectedView.Text;
    //     // GroupEventsByView(view);
    // }
    private DateTime? _lastDate;
    private string? _lastView;

    protected override void OnAfterRender(bool firstRender)
    {
        if (scheduler == null)
            return;

        // Initialize once when scheduler becomes available
        if (!_schedulerInitialized)
        {
            _lastView = scheduler.SelectedView?.Text;
            _lastDate = scheduler.CurrentDate;
            _schedulerInitialized = true;
            return;
        }

        var currentView = scheduler.SelectedView?.Text;
        var currentDate = scheduler.CurrentDate;

        // 🚨 No change → exit
        if (_lastView == currentView && _lastDate == currentDate)
            return;

        // ✅ Change detected
        _lastView = currentView;
        _lastDate = currentDate;

        // Update list only when list view is active
        if (!showCalendar)
        {
            GroupEventsByView(currentView!, currentDate);
            InvokeAsync(StateHasChanged);
        }
    }
    private void GroupEventsByView(string view, DateTime baseDate)
    {
        if (calendarEvents == null)
            return;

        IEnumerable<MyEventViewModel> filtered;

        if (view == "Month")
        {
            var start = new DateTime(baseDate.Year, baseDate.Month, 1);
            var end = start.AddMonths(1);

            filtered = calendarEvents
                .Where(e => e.Start >= start && e.Start < end);
        }
        else if (view == "Week")
        {
            var diff = (7 + (baseDate.DayOfWeek - System.DayOfWeek.Monday)) % 7;
            var start = baseDate.Date.AddDays(-diff);
            var end = start.AddDays(7);

            filtered = calendarEvents
                .Where(e => e.Start >= start && e.Start < end);
        }
        else // Day
        {
            filtered = calendarEvents
                .Where(e => e.Start.Date == baseDate.Date);
        }

        GroupedEvents = filtered
            .GroupBy(e => e.Start.Date)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

