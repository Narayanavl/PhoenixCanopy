    <div class="calendar-container">
        <div class="scheduler-wrapper">

            <RadzenButton Text="@ToggleButtonText"
                          Click="@ToggleView"
                          Icon="List"
                          class="scheduler-custom-button" />

            <div class="calendar-wrapper @(showCalendar ? "calendar-mode" : "list-mode")">
                <RadzenScheduler TItem="MyEventViewModel"
                                 Data="@calendarEvents"
                                 StartProperty="Start"
                                 EndProperty="End"
                                 TextProperty="Subject"
                                 Style="height: 400px;"
                                 @ref="scheduler">

                    <RadzenMonthView/>
                    <RadzenWeekView />
                    <RadzenDayView />
                </RadzenScheduler>
            </div>

            @if (!showCalendar)
            {
                if (GroupedEvents != null && GroupedEvents.Count > 0)
                {
                    <div class="event-list-container">
                        @foreach (var dayGroup in GroupedEvents)
                        {
                            <div class="day-group">
                                <div class="day-header-left">
                                    <strong>@dayGroup.Key.ToString("dddd")</strong>
                                    <div class="event-items">
                                        @foreach (var ev in dayGroup.Value)
                                        {
                                            <div class="event-item">
                                                <span class="event-time">@ev.Start.ToString("hh:mmtt").ToLower()</span>
                                                <span class="event-dot"></span>
                                                <span class="event-text">@ev.Subject</span>
                                            </div>
                                        }
                                    </div>
                                </div>
                                <div class="day-header-right">
                                    @dayGroup.Key.ToString("MMMM dd, yyyy")
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="no-events">
                        <p>No events to display</p>
                    </div>
                }
            }
        </div>
    </div>

</div>


