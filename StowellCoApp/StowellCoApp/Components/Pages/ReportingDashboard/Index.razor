<script>
    $(document).ready(function () {

        document.getElementById('ajcs').addEventListener('click', function (event) {
            // Prevent the default action (navigation) from happening immediately
            event.preventDefault();

            // Get the defaultJobId from localStorage
            const defaultJobId = localStorage.getItem('defaultJobId');
            var url = '/CostCodeSummary';
            // Check if defaultJobId exists
            if (defaultJobId) {
                // Dynamically create the URL and navigate to it
                url = `/CostCodeSummary/${defaultJobId}`;
            }
            window.open(url, '_blank');  // Open in a new tab
        });


    });
</script>
