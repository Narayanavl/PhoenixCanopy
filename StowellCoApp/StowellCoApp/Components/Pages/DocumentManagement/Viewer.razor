 @* @page "/file-viewer"
@using Microsoft.AspNetCore.WebUtilities
@using Syncfusion.Blazor.SfPdfViewer
@using Syncfusion.Blazor.DocumentEditor
@using Syncfusion.Blazor.Spreadsheet
@inject NavigationManager NavManager
@inject IConfiguration Config

<PageTitle>File Viewer</PageTitle>

<div style="height:100vh; width:100%;">

    @if (!string.IsNullOrEmpty(FileName))
    {
        @if (IsPdf)
        {
            <SfPdfViewer2 DocumentPath="@FileUrl"
                          Height="100%"
                          Width="100%" />
        }
        else if (IsDocx)
        {
            <SfDocumentEditorContainer @ref="DocEditor"
                                       Height="100%"
                                       Width="100%" />
        }
        else if (IsXlsx)
        {
            <SfSpreadsheet @ref="Spreadsheet"
                           Height="100%"
                           Width="100%" />
        }
        else if (IsTxt)
        {
            <div style="padding:20px; height:100%; overflow:auto;">
                <pre style="white-space:pre-wrap">@TextContent</pre>
            </div>
        }
    }

</div>

@code {

    private string FileName;
    private string FolderName;
    private string FilterPath;
    private string FileUrl;
    private string TextContent;

    private SfDocumentEditorContainer DocEditor;
    private SfSpreadsheet Spreadsheet;

    private string apiUrl;

    private bool IsPdf => FileName?.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsDocx => FileName?.EndsWith(".docx", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsXlsx => FileName?.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase) == true;
    private bool IsTxt => FileName?.EndsWith(".txt", StringComparison.OrdinalIgnoreCase) == true;

    protected override async Task OnInitializedAsync()
    {
        apiUrl = Config["APIBaseUrl"];

        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("name", out var name))
            FileName = name;

        if (query.TryGetValue("folder", out var folder))
            FolderName = folder;

        if (query.TryGetValue("path", out var path))
            FilterPath = path;

        FileUrl =
            $"{apiUrl}api/DocumentManagement/GetFile" +
            $"?foldername={Uri.EscapeDataString(FolderName)}" +
            $"&name={Uri.EscapeDataString(FileName)}" +
            $"&filterPath={Uri.EscapeDataString(FilterPath)}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            using var http = new HttpClient();
            var bytes = await http.GetByteArrayAsync(FileUrl);

            if (IsDocx && DocEditor != null)
            {
                using var ms = new MemoryStream(bytes);
                await DocEditor.DocumentEditor.OpenAsync(ms, Syncfusion.Blazor.DocumentEditor.ImportFormatType.Docx);
            }
            else if (IsXlsx && Spreadsheet != null)
            {
                using var ms = new MemoryStream(bytes);
               // await Spreadsheet.OpenAsync(ms);
            }
            else if (IsTxt)
            {
                TextContent = System.Text.Encoding.UTF8.GetString(bytes);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Viewer error: {ex.Message}");
        }
    }
} *@
